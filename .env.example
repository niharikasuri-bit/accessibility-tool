# ─── API public URL (required for PDF links in scheduled emails) ────────────
# The URL where the API server is reachable by email recipients.
# For local dev this is fine for testing; for real external recipients deploy
# the API and set this to the deployed URL.
API_PUBLIC_URL=http://localhost:3000

# ─── Supabase Storage (optional — truly permanent public PDF URLs) ───────────
# If set, PDFs are uploaded to Supabase and served from there instead of the
# API server. Links survive API restarts and work regardless of server uptime.
# Setup:
#   1. Create a free project at https://supabase.com
#   2. Storage > New bucket  Name: accessibility-pdfs  Public: ON
#   3. Copy URL + anon key from Project Settings > API
#
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
